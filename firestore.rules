rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Profiles: Users can only read/write their own profile
    match /profiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Incidents: Any authenticated user can report an incident. 
    // Admins and assigned Volunteers can update them.
    match /incidents/{incidentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null; 
    }
    
    // Volunteers: Authenticated users can see the roster.
    match /volunteers/{volunteerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Alert Logs & Timeline: Public read for coordination, restricted write
    match /alert_logs/{logId} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }

    match /incident_timeline/{eventId} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }
  }
}
